<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Welcome to Dictionary</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu,
          Cantarell, sans-serif;
        line-height: 1.6;
        color: #333;
        background-color: #f8f9fa;
      }

      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      }

      .header h1 {
        color: white;
        margin: 0;
        font-size: 28px;
        font-weight: 600;
      }

      .header p {
        color: rgba(255, 255, 255, 0.9);
        margin: 10px 0 0 0;
        font-size: 16px;
      }

      .content {
        padding: 40px 30px;
      }

      .welcome-message {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        padding: 25px;
        border-radius: 8px;
        margin: 20px 0;
        text-align: center;
      }

      .cta {
        background-color: #f37e2c;
        color: white;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 6px;
        display: inline-block;
        font-weight: 600;
        margin: 20px 0;
      }

      .support {
        background-color: #ffe8d9;
        border-left: 4px solid #f37e2c;
        padding: 15px;
        margin: 25px 0;
        border-radius: 4px;
      }

      .support p {
        margin: 0;
        color: #b54e00;
      }

      .footer {
        background-color: #f8f9fa;
        padding: 25px 30px;
        text-align: center;
        border-top: 1px solid #dee2e6;
      }

      .footer p {
        margin: 5px 0;
        color: #666;
        font-size: 14px;
      }

      .brand {
        color: #f37e2c;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div
        class='header'
        style='background: orange; padding: 40px 20px; text-align: center;'
      >
        <h1>Welcome to Dictionary!</h1>
        <p>Please verify your email to activate your account</p>
      </div>

      <div class='content'>
        <div class='welcome-message'>
          <h2 style='margin: 0; color: #f37e2c;'>Hello {{fullName}}!</h2>
          <p style='margin: 15px 0 0 0; font-size: 16px;'>
            Your account has been created successfully.
          </p>
        </div>

        <p>Please confirm your email address by clicking the button below:</p>

        <p>This verification link will remain valid for 15 minutes from the time this email was sent.</p>

        <div style='text-align: center;'>
          <a href='{{verificationUrl}}' class='cta'>Verify Email</a>
        </div>

        <div class='support'>
          <p>
            <strong>Verification link:</strong>
            If the button does not work, open this link in your browser:
            <br />
            <a href='{{verificationUrl}}'>{{verificationUrl}}</a>
          </p>
        </div>

        <p>If you did not create this account, you can safely ignore this email.</p>
      </div>

      <div class='footer'>
        <p>Best regards,<br /><span class='brand'>The Dictionary Team</span></p>
        <p style='margin-top: 15px; font-size: 12px; color: #999;'>
          This email was sent automatically. Please do not reply to this email.
        </p>
      </div>
    </div>
  </body>
</html>
